<h2>Booking Confirmed!</h2>

<p>Hi <%= @user.email %>,</p>

<p>Your booking has been confirmed. Here are the details:</p>

<table style="border-collapse: collapse; width: 100%; max-width: 500px;">
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Resource:</td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @resource.name %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Date:</td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @booking.booking_date.strftime("%A, %B %d, %Y") %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Time:</td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @booking.time_range_display %></td>
  </tr>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Duration:</td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @booking.duration_minutes %> minutes</td>
  </tr>
  <% if @booking.total_cost.to_f > 0 %>
    <tr>
      <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Cost:</td>
      <td style="padding: 8px; border: 1px solid #ddd;">$<%= sprintf("%.2f", @booking.total_cost) %></td>
    </tr>
  <% end %>
  <tr>
    <td style="padding: 8px; border: 1px solid #ddd; font-weight: bold;">Purpose:</td>
    <td style="padding: 8px; border: 1px solid #ddd;"><%= @booking.purpose %></td>
  </tr>
</table>

<p>Thank you for using the CUHK Booking System.</p>
