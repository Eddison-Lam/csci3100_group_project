<% if user_signed_in? %>
  <h1>Welcome, <%= current_user.email %></h1>

  <div style="display: flex; gap: 20px; margin-top: 30px; flex-wrap: wrap;">
    <%= link_to rooms_path, style: "text-decoration: none; color: inherit;" do %>
      <div style="background: #3498db; color: white; padding: 30px 40px; border-radius: 8px; text-align: center; min-width: 200px; cursor: pointer;">
        <h2 style="margin: 0 0 10px;">📅 Book a Room</h2>
        <p style="margin: 0;">Browse and reserve available rooms</p>
      </div>
    <% end %>

    <%= link_to equipment_index_path, style: "text-decoration: none; color: inherit;" do %>
      <div style="background: #2ecc71; color: white; padding: 30px 40px; border-radius: 8px; text-align: center; min-width: 200px; cursor: pointer;">
        <h2 style="margin: 0 0 10px;">🔧 Book Equipment</h2>
        <p style="margin: 0;">Browse and reserve available equipment</p>
      </div>
    <% end %>

    <%= link_to bookings_path, style: "text-decoration: none; color: inherit;" do %>
      <div style="background: #9b59b6; color: white; padding: 30px 40px; border-radius: 8px; text-align: center; min-width: 200px; cursor: pointer;">
        <h2 style="margin: 0 0 10px;">📋 My Bookings</h2>
        <p style="margin: 0;">View and manage your bookings</p>
      </div>
    <% end %>
  </div>

  <% upcoming = current_user.bookings.where("booking_date >= ?", Date.current).where(status: :confirmed).order(:booking_date, :start_slot).limit(5) %>
  <% if upcoming.any? %>
    <h2 style="margin-top: 40px;">Upcoming Bookings</h2>
    <table style="width: 100%; border-collapse: collapse;">
      <thead>
        <tr style="background: #ecf0f1;">
          <th style="padding: 10px; text-align: left;">Resource</th>
          <th style="padding: 10px; text-align: left;">Date</th>
          <th style="padding: 10px; text-align: left;">Time</th>
          <th style="padding: 10px; text-align: left;">Status</th>
        </tr>
      </thead>
      <tbody>
        <% upcoming.each do |booking| %>
          <tr style="border-bottom: 1px solid #ddd;">
            <td style="padding: 10px;"><%= booking.resource.name %></td>
            <td style="padding: 10px;"><%= booking.booking_date.strftime("%b %d, %Y") %></td>
            <td style="padding: 10px;"><%= booking.time_range_display %></td>
            <td style="padding: 10px;"><span style="background: #27ae60; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.85em;"><%= booking.status.capitalize %></span></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
<% else %>
  <h1>CUHK Venue & Equipment Booking</h1>
  <p>Please log in to access the booking system.</p>
  <div style="margin-top: 20px;">
    <%= link_to "Register", new_user_registration_path, style: "background: #3498db; color: white; padding: 10px 20px; border-radius: 4px; text-decoration: none; margin-right: 10px;" %>
    <%= link_to "Login", new_user_session_path, style: "background: #2ecc71; color: white; padding: 10px 20px; border-radius: 4px; text-decoration: none;" %>
  </div>
<% end %>
