<!-- Landing page: 2 states — hero for guests, welcome dashboard for logged-in users -->

<% if user_signed_in? %>
  <!-- ===== Logged-in state ===== -->
  <div class="min-h-[70vh] flex items-center justify-center px-4">
    <div class="w-full max-w-lg bg-white rounded-2xl shadow-lg p-10 text-center space-y-6">

      <!-- Logo -->
      <%= image_tag "logo.png", alt: "CUHK Booking Logo", class: "h-20 w-auto mx-auto mb-2" %>

      <h1 class="text-2xl font-bold text-gray-800">Welcome back!</h1>

      <p class="text-gray-500 text-sm">
        目前登入者：<span class="font-medium text-gray-700"><%= current_user.email %></span>
      </p>

      <!-- Role badge so users know what account type they have -->
      <span class="inline-block rounded-full px-3 py-1 text-xs font-semibold
        <%= current_user.admin? || current_user.superadmin? ? 'bg-amber-100 text-amber-700' : 'bg-indigo-100 text-indigo-700' %>">
        <%= current_user.role.capitalize %>
      </span>

      <!-- Quick action buttons -->
      <div class="pt-4 border-t border-gray-100 space-y-3">
        <%= button_to "Log Out", destroy_user_session_path, method: :delete,
            form: { data: { turbo: false } },
            class: "w-full rounded-lg border border-red-300 text-red-600 px-4 py-2.5 text-sm font-semibold hover:bg-red-50 transition cursor-pointer" %>
      </div>
    </div>
  </div>

<% else %>
  <!-- ===== Guest state: full landing page ===== -->
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-50 to-indigo-50 px-4">
    <div class="w-full max-w-xl text-center space-y-8">

      <!-- Logo -->
      <%= image_tag "logo.png", alt: "CUHK Booking Logo", class: "h-24 w-auto mx-auto mb-6" %>

      <!-- Headline and subtitle -->
      <div class="space-y-3">
        <h1 class="text-4xl sm:text-5xl font-extrabold text-gray-900 tracking-tight">
          CUHK Venue &amp; Equipment Booking System
        </h1>
      </div>

      <!-- CTA buttons side-by-side -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 pt-2">
        <%= link_to "Login", new_user_session_path,
            class: "w-full sm:w-auto inline-block rounded-lg bg-indigo-600 px-8 py-3 text-sm font-semibold text-white shadow-md hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 transition" %>

        <%= link_to "Register", new_user_registration_path,
            class: "w-full sm:w-auto inline-block rounded-lg border border-indigo-600 px-8 py-3 text-sm font-semibold text-indigo-600 hover:bg-indigo-50 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 transition" %>
      </div>
    </div>
  </div>
<% end %>
