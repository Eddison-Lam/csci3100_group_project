<div class="min-h-screen bg-gray-50">
  <div class="max-w-7xl mx-auto py-8 px-4">

    <!-- Header -->
    <div class="mb-10">
      <h1 class="text-4xl font-bold text-gray-900 mb-2">Available Venues & Equipment</h1>
      <p class="text-lg text-gray-500">Search and reserve CUHK campus rooms and equipment</p>
    </div>

    <!-- Filter / Search bar (UI only — backend wiring later) -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 mb-8">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-4 items-end">

        <div class="md:col-span-2">
          <label class="block text-sm font-medium text-gray-700 mb-1">Search</label>
          <input
            type="text"
            placeholder="Search by name or location…"
            class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none"
          />
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
          <select class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none bg-white cursor-pointer">
            <option value="">All Types</option>
            <option value="Room">Rooms</option>
            <option value="Equipment">Equipment</option>
          </select>
        </div>

        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Min. Capacity</label>
          <select class="w-full rounded-lg border border-gray-300 px-3 py-2.5 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none bg-white cursor-pointer">
            <option value="">Any Size</option>
            <option value="10">10+ people</option>
            <option value="20">20+ people</option>
            <option value="50">50+ people</option>
            <option value="100">100+ people</option>
          </select>
        </div>

      </div>
    </div>

    <!-- Resource grid -->
    <% if @resources.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% @resources.each do |resource| %>
          <div class="bg-white rounded-xl shadow-sm border border-gray-200 hover:shadow-md overflow-hidden transition duration-200 flex flex-col">

            <!-- Placeholder image -->
            <div class="h-48 w-full flex items-center justify-center <%= resource.is_a?(Room) ? 'bg-gradient-to-br from-indigo-100 to-blue-50' : 'bg-gradient-to-br from-emerald-100 to-teal-50' %>">
              <% if resource.is_a?(Room) %>
                <svg class="h-14 w-14 text-indigo-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
                </svg>
              <% else %>
                <svg class="h-14 w-14 text-emerald-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.049.58.025 1.193-.14 1.743" />
                </svg>
              <% end %>
            </div>

            <!-- Card body -->
            <div class="p-5 flex-grow flex flex-col">

              <h3 class="text-lg font-bold text-gray-900 mb-2"><%= resource.name %></h3>

              <!-- Badges -->
              <div class="flex flex-wrap gap-2 mb-3">
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold <%= resource.is_a?(Room) ? 'bg-indigo-100 text-indigo-700' : 'bg-emerald-100 text-emerald-700' %>">
                  <%= resource.type %>
                </span>

                <% if resource.room_type.present? %>
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-indigo-50 text-indigo-600">
                    <%= resource.room_type %>
                  </span>
                <% end %>

                <% if resource.is_a?(Room) && resource.capacity.present? %>
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-blue-100 text-blue-700">
                    <%= resource.capacity %> seats
                  </span>
                <% elsif resource.is_a?(Equipment) && resource.quantity.present? %>
                  <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-semibold bg-blue-100 text-blue-700">
                    Qty: <%= resource.quantity %>
                  </span>
                <% end %>
              </div>

              <!-- Description / Location -->
              <div class="text-sm text-gray-600 mb-3 flex-grow">
                <% if resource.is_a?(Room) && resource.location.present? %>
                  <p><span class="font-medium text-gray-700"><%= resource.building %></span> — <%= resource.location %></p>
                <% elsif resource.description.present? %>
                  <p><%= truncate(resource.description, length: 100) %></p>
                <% else %>
                  <p class="italic text-gray-400">No description available</p>
                <% end %>
              </div>

              <!-- Operating hours -->
              <p class="text-xs text-gray-400 mb-4">
                Open: <%= resource.operating_hours_display %>
              </p>

              <!-- CTA -->
              <%= link_to "Check Availability", polymorphic_path(resource),
                  class: "block w-full text-center rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 transition" %>
            </div>

          </div>
        <% end %>
      </div>

    <% else %>
      <!-- Empty state -->
      <div class="flex items-center justify-center py-24">
        <div class="text-center">
          <svg class="h-16 w-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
          </svg>
          <h3 class="text-lg font-semibold text-gray-900 mb-1">No resources currently available</h3>
          <p class="text-sm text-gray-500">Check back later or adjust your search filters.</p>
        </div>
      </div>
    <% end %>

  </div>
</div>
