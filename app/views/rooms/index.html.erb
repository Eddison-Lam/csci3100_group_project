<h1>Browse Rooms</h1>

<!-- Filters -->
<div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
  <%= form_with url: rooms_path, method: :get, local: true, style: "display: flex; gap: 15px; flex-wrap: wrap; align-items: end;" do %>
    <div>
      <label style="display: block; font-weight: bold; margin-bottom: 5px;">Building</label>
      <%= select_tag "buildings[]",
            options_for_select(@buildings, params[:buildings]),
            include_blank: "All Buildings",
            style: "padding: 8px; border-radius: 4px; border: 1px solid #ccc;" %>
    </div>

    <div>
      <label style="display: block; font-weight: bold; margin-bottom: 5px;">Room Type</label>
      <%= select_tag "room_types[]",
            options_for_select(@room_types, params[:room_types]),
            include_blank: "All Types",
            style: "padding: 8px; border-radius: 4px; border: 1px solid #ccc;" %>
    </div>

    <div>
      <label style="display: block; font-weight: bold; margin-bottom: 5px;">Min Capacity</label>
      <%= number_field_tag :capacity, params[:capacity], min: 1, placeholder: "Any",
            style: "padding: 8px; border-radius: 4px; border: 1px solid #ccc; width: 100px;" %>
    </div>

    <div>
      <%= submit_tag "Search", style: "background: #3498db; color: white; border: none; padding: 10px 20px; border-radius: 4px; cursor: pointer;" %>
    </div>
  <% end %>
</div>

<!-- Room List -->
<% if @rooms.any? %>
  <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;">
    <% @rooms.each do |room| %>
      <%= link_to room_path(room), style: "text-decoration: none; color: inherit;" do %>
        <div style="border: 1px solid #ddd; border-radius: 8px; padding: 20px; background: white; transition: box-shadow 0.2s; cursor: pointer;"
             onmouseover="this.style.boxShadow='0 4px 12px rgba(0,0,0,0.15)'"
             onmouseout="this.style.boxShadow='none'">
          <h3 style="margin: 0 0 8px; color: #2c3e50;"><%= room.name %></h3>
          <p style="margin: 4px 0; color: #7f8c8d;">
            📍 <%= room.building %> — <%= room.location %>
          </p>
          <p style="margin: 4px 0; color: #7f8c8d;">
            👥 Capacity: <%= room.capacity || "N/A" %>
            <% if room.room_type.present? %>
              &nbsp;|&nbsp; Type: <%= room.room_type %>
            <% end %>
          </p>
          <p style="margin: 4px 0;">
            <% if room.price_per_unit.to_f > 0 %>
              <span style="background: #e67e22; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.85em;">
                $<%= room.price_per_unit %>/slot
              </span>
            <% else %>
              <span style="background: #27ae60; color: white; padding: 2px 8px; border-radius: 4px; font-size: 0.85em;">Free</span>
            <% end %>
          </p>
          <p style="margin: 4px 0; color: #95a5a6; font-size: 0.9em;">
            Hours: <%= room.operating_hours_display %>
          </p>
        </div>
      <% end %>
    <% end %>
  </div>
<% else %>
  <p style="color: #7f8c8d; font-style: italic;">No rooms found matching your criteria.</p>
<% end %>
