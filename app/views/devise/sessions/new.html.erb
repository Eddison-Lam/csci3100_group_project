<!-- Login page: centered light gray card style-->
<div class="min-h-screen flex items-center justify-center bg-gray-50 px-4 py-12">
  <div class="w-full max-w-md space-y-6">

    <!-- Brand header -->
    <div class="text-center">
      <h1 class="text-3xl font-bold text-indigo-600">CUHK Booking</h1>
      <p class="mt-1 text-sm text-gray-500">Venue & Equipment Booking System</p>
    </div>

    <!-- White card that holds everything -->
    <div class="bg-white rounded-2xl shadow-lg p-8 space-y-6">

      <h2 class="text-xl font-semibold text-gray-800">Log in</h2>

      <!-- Devise form — all Ruby logic kept exactly as-is -->
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>

        <!-- Email field -->
        <div class="mb-4">
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-600 outline-none" %>
        </div>

        <!-- Password field -->
        <div class="mb-4">
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.password_field :password, autocomplete: "current-password",
              class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm shadow-sm focus:border-indigo-500 focus:ring-1 focus:ring-indigo-600 outline-none" %>
        </div>

        <!-- Remember-me checkbox: only shows if Devise has rememberable enabled -->
        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2 mb-5">
            <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-gray-300 text-indigo-600 focus:ring-indigo-600" %>
            <%= f.label :remember_me, class: "text-sm text-gray-600" %>
          </div>
        <% end %>

        <!-- Submit button -->
        <div>
          <%= f.submit "Log in",
              class: "w-full rounded-lg bg-indigo-600 px-4 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 focus:outline-none focus:ring-2 focus:ring-indigo-600 focus:ring-offset-2 cursor-pointer transition" %>
        </div>
      <% end %>

      <!-- Devise shared links (sign up, forgot password... etc) -->
      <div class="text-center text-sm text-gray-500 space-y-1 pt-2 border-t border-gray-100">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
