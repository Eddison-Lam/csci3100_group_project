<!-- Here is the admin login page layout-->
<!DOCTYPE html>
<html>
  <head>
    <title>Admin Dashboard - CSCI3100 Booking System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Include your application CSS and JS %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <%# Simple inline styles for a quick sidebar layout (Move to a CSS file later) %>
    <style>
      body { margin: 0; font-family: sans-serif; display: flex; height: 100vh; }
      .admin-sidebar { width: 250px; background-color: #2c3e50; color: white; padding: 20px; }
      .admin-sidebar h2 { margin-top: 0; border-bottom: 1px solid #34495e; padding-bottom: 10px; }
      .admin-sidebar a { color: #ecf0f1; text-decoration: none; display: block; margin: 10px 0; padding: 5px; }
      .admin-sidebar a:hover { background-color: #34495e; border-radius: 4px; }
      .admin-content { flex-grow: 1; padding: 20px; background-color: #f4f6f6; overflow-y: auto; }
      .flash-messages { margin-bottom: 20px; padding: 10px; background: #d4edda; border: 1px solid #c3e6cb; color: #155724; border-radius: 4px; }
    </style>
  </head>

  <body>
    <!-- Admin Sidebar -->
    <div class="admin-sidebar">
      <h2>Admin Panel</h2>
      <p>Dept: <%= current_user&.department&.name || "N/A" %></p>
      
      <nav>
        <%= link_to "Resource Browser", admin_resources_path %>
        <!-- You can add these later: -->
        <!-- <%= link_to "Manage Bookings", '#' %> -->
        <!-- <%= link_to "User Management", '#' %> -->
        <hr style="border-color: #34495e; margin: 20px 0;">
        <%= button_to "Log Out", destroy_user_session_path, method: :delete, form: { data: { turbo: false } }, style: "background: #c0392b; color: white; border: none; padding: 8px 12px; cursor: pointer; border-radius: 4px; width: 100%;" %>
      </nav>
    </div>

    <!-- Main Content Area -->
    <div class="admin-content">
      <%# Flash messages for success/error notifications %>
      <% if notice %>
        <div class="flash-messages notice"><%= notice %></div>
      <% end %>
      <% if alert %>
        <div class="flash-messages alert" style="background: #f8d7da; border-color: #f5c6cb; color: #721c24;"><%= alert %></div>
      <% end %>

      <%# This is where your admin/resources/index.html.erb will be injected %>
      <%= yield %>
    </div>
  </body>
</html>