<!DOCTYPE html>
<html class="h-full">
  <head>
    <title>CSCI3100 Booking System</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= favicon_link_tag 'icon.ico' %>

    <%= yield :head %>

    <script src="https://cdn.tailwindcss.com"></script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full bg-slate-800">

    <% if user_signed_in? %>
      <!-- Mobile overlay -->
      <div id="sidebar-overlay" class="fixed inset-0 z-30 bg-black/50 hidden lg:hidden" onclick="toggleSidebar()"></div>

      <!-- Mobile hamburger -->
      <button onclick="toggleSidebar()" class="fixed top-4 left-4 z-40 lg:hidden rounded-lg bg-slate-700 p-2 text-white shadow-lg hover:bg-slate-600 transition">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/>
        </svg>
      </button>

      <!-- Sidebar -->
      <aside id="sidebar" class="fixed inset-y-0 left-0 z-40 flex flex-col bg-slate-800 transition-all duration-300 w-64 -translate-x-full lg:translate-x-0">

        <!-- Logo + title -->
        <div class="flex flex-col items-center gap-2 px-4 pt-6 pb-4">
          <div class="bg-white rounded-xl p-1">
            <%= image_tag "logo.png",
                  alt:   "CSCI3100 Booking Logo",
                  id:    "sidebar-logo",
                  class: "h-20 w-auto transition-all duration-300" %>
          </div>
          <span id="sidebar-title" class="text-lg font-semibold text-white tracking-wide transition-opacity duration-300">Student Portal</span>
          <span id="sidebar-dept" class="text-xs text-slate-400 transition-opacity duration-300">
            Dept: <%= current_user&.department&.name || "N/A" %>
          </span>
        </div>

        <!-- Nav -->
        <nav class="flex-1 px-3 py-4 overflow-y-auto">
          <div class="flex flex-col space-y-2">
            <%= link_to root_path, title: "Home", class: "sidebar-link group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition" do %>
              <svg class="sidebar-icon h-5 w-5 shrink-0 text-slate-400 group-hover:text-white transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955a1.126 1.126 0 0 1 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/>
              </svg>
              <span class="sidebar-label transition-opacity duration-300">Home</span>
            <% end %>

            <%= link_to rooms_path, title: "Book a Room", class: "sidebar-link group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition" do %>
              <svg class="sidebar-icon h-5 w-5 shrink-0 text-slate-400 group-hover:text-white transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21"/>
              </svg>
              <span class="sidebar-label transition-opacity duration-300">Book a Room</span>
            <% end %>

            <%= link_to equipment_index_path, title: "Book Equipment", class: "sidebar-link group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition" do %>
              <svg class="sidebar-icon h-5 w-5 shrink-0 text-slate-400 group-hover:text-white transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.58.025 1.193-.14 1.743"/>
              </svg>
              <span class="sidebar-label transition-opacity duration-300">Book Equipment</span>
            <% end %>

            <%= link_to bookings_path, title: "My Bookings", class: "sidebar-link group flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm font-medium text-slate-300 hover:bg-slate-700 hover:text-white transition" do %>
              <svg class="sidebar-icon h-5 w-5 shrink-0 text-slate-400 group-hover:text-white transition" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15a2.25 2.25 0 0 1 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/>
              </svg>
              <span class="sidebar-label transition-opacity duration-300">My Bookings</span>
            <% end %>
          </div>
        </nav>

        <!-- Logout + collapse toggle -->
        <div class="px-3 py-3">
          <div id="logout-wrapper">
            <%= button_to destroy_user_session_path, method: :delete, form: { data: { turbo: false }, class: "w-full", id: "logout-form" }, class: "logout-btn w-full flex items-center justify-center gap-2 rounded-lg bg-red-600 px-3 py-2 text-sm font-medium text-white hover:bg-red-500 transition", id: "logout-btn", title: "Log Out" do %>
              <svg class="h-5 w-5 shrink-0" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 9V5.25A2.25 2.25 0 0 1 10.5 3h6a2.25 2.25 0 0 1 2.25 2.25v13.5A2.25 2.25 0 0 1 16.5 21h-6a2.25 2.25 0 0 1-2.25-2.25V15m-3 0-3-3m0 0 3-3m-3 3H15"/>
              </svg>
              <span class="sidebar-label transition-opacity duration-300">Log Out</span>
            <% end %>
          </div>

          <!-- Collapse toggle (desktop) -->
          <button id="collapse-btn" onclick="collapseSidebar()" class="hidden lg:flex mt-2 w-full items-center justify-center rounded-md p-1.5 text-slate-400 hover:bg-slate-700 hover:text-white transition">
            <svg id="chevron-collapse" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/>
            </svg>
            <svg id="chevron-expand" class="h-4 w-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/>
            </svg>
          </button>
        </div>
      </aside>

      <!-- Main content -->
      <div id="main-wrapper" class="transition-all duration-300 lg:ml-64 min-h-screen">
        <div class="min-h-screen bg-gray-50 lg:rounded-tl-3xl lg:rounded-bl-3xl">
          <div class="h-16 lg:hidden"></div>

          <div class="p-6 sm:p-8">
            <% if notice %>
              <div class="mb-6 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
                <%= notice %>
              </div>
            <% end %>
            <% if alert %>
              <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
                <%= alert %>
              </div>
            <% end %>

            <%= yield %>
          </div>
        </div>
      </div>

    <% else %>
      <!-- Logged-out layout -->
      <div class="min-h-screen bg-gray-50">
        <div class="p-6 sm:p-8">
          <% if notice %>
            <div class="mb-6 rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-800">
              <%= notice %>
            </div>
          <% end %>
          <% if alert %>
            <div class="mb-6 rounded-lg border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
              <%= alert %>
            </div>
          <% end %>

          <%= yield %>
        </div>
      </div>
    <% end %>

    <script>
      function initSidebar() {
        var sidebar  = document.getElementById('sidebar');
        var overlay  = document.getElementById('sidebar-overlay');
        var mainWrap = document.getElementById('main-wrapper');
        if (!sidebar) return;

        var saved = localStorage.getItem('sidebar-collapsed') === 'true';
        if (saved) applyCollapsed(true);

        window.toggleSidebar = function() {
          sidebar.classList.toggle('-translate-x-full');
          if (overlay) overlay.classList.toggle('hidden');
        };

        window.collapseSidebar = function() {
          var isCollapsed = sidebar.classList.contains('w-[4.5rem]');
          var next = !isCollapsed;
          localStorage.setItem('sidebar-collapsed', next);
          applyCollapsed(next);
        };

        function applyCollapsed(collapsed) {
          var labels    = document.querySelectorAll('.sidebar-label');
          var logo      = document.getElementById('sidebar-logo');
          var title     = document.getElementById('sidebar-title');
          var dept      = document.getElementById('sidebar-dept');
          var chevL     = document.getElementById('chevron-collapse');
          var chevR     = document.getElementById('chevron-expand');
          var links     = document.querySelectorAll('.sidebar-link');
          var logoutBtn = document.getElementById('logout-btn');
          var logoutForm = document.getElementById('logout-form');

          if (collapsed) {
            sidebar.classList.replace('w-64', 'w-[4.5rem]');
            if (mainWrap) {
              mainWrap.classList.remove('lg:ml-64');
              mainWrap.classList.add('lg:ml-[4.5rem]');
            }

            labels.forEach(function(l) { l.classList.add('opacity-0', 'w-0', 'overflow-hidden'); });

            links.forEach(function(a) {
              a.classList.remove('gap-3', 'px-3', 'py-2.5', 'hover:bg-slate-700');
              a.classList.add('w-10', 'h-10', 'justify-center', 'mx-auto');
            });

            if (logo) { logo.classList.remove('h-20'); logo.classList.add('h-10'); }
            if (title) title.classList.add('hidden');
            if (dept) dept.classList.add('hidden');
            if (chevL) chevL.classList.add('hidden');
            if (chevR) chevR.classList.remove('hidden');

            if (logoutBtn) {
              logoutBtn.classList.remove('w-full', 'gap-2', 'px-3', 'py-2');
              logoutBtn.classList.add('w-10', 'h-10', 'mx-auto');
            }
            if (logoutForm) {
              logoutForm.classList.remove('w-full');
              logoutForm.classList.add('flex', 'justify-center');
            }
          } else {
            sidebar.classList.replace('w-[4.5rem]', 'w-64');
            if (mainWrap) {
              mainWrap.classList.remove('lg:ml-[4.5rem]');
              mainWrap.classList.add('lg:ml-64');
            }

            labels.forEach(function(l) { l.classList.remove('opacity-0', 'w-0', 'overflow-hidden'); });

            links.forEach(function(a) {
              a.classList.add('gap-3', 'px-3', 'py-2.5', 'hover:bg-slate-700');
              a.classList.remove('w-10', 'h-10', 'justify-center', 'mx-auto');
            });

            if (logo) { logo.classList.remove('h-10'); logo.classList.add('h-20'); }
            if (title) title.classList.remove('hidden');
            if (dept) dept.classList.remove('hidden');
            if (chevL) chevL.classList.remove('hidden');
            if (chevR) chevR.classList.add('hidden');

            if (logoutBtn) {
              logoutBtn.classList.add('w-full', 'gap-2', 'px-3', 'py-2');
              logoutBtn.classList.remove('w-10', 'h-10', 'mx-auto');
            }
            if (logoutForm) {
              logoutForm.classList.add('w-full');
              logoutForm.classList.remove('flex', 'justify-center');
            }
          }
        }
      }

      document.addEventListener('turbo:load', initSidebar);
      document.addEventListener('DOMContentLoaded', initSidebar);
    </script>
  </body>
</html>
